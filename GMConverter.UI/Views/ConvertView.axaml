<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GMConverter.UI.ViewModels"
             xmlns:common="using:GMConverter.UI.Controls.Common"
             xmlns:shad="clr-namespace:ShadUI;assembly=ShadUI"
             xmlns:controls="clr-namespace:GMConverter.UI.Controls"
             mc:Ignorable="d"
             d:DesignWidth="900"
             d:DesignHeight="720"
             x:Class="GMConverter.UI.Views.ConvertView"
             x:DataType="vm:ConvertViewModel">
    <DockPanel LastChildFill="True">
        <common:Header DockPanel.Dock="Top"
                           Title="Convert"
                           Description="Configure conversion inputs and export settings.">
            <common:Header.RightContent>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <shad:Badge Variant="Outline" Content="{Binding SelectedAxisMode.Label}"/>
                    <shad:Badge Variant="Outline" Content="{Binding SelectedPhysicsMode.Label}"/>
                </StackPanel>
            </common:Header.RightContent>
        </common:Header>

        <controls:ScrollProgress>
            <controls:ScrollProgress.ScrollContent>
            <StackPanel Margin="48,0,48,24"
                        HorizontalAlignment="Stretch"
                        MaxWidth="{StaticResource PageMaxWidth}"
                        Spacing="16">
                <UniformGrid Columns="2" ColumnSpacing="16">
                    <shad:Card HasShadow="True">
                        <shad:Card.Header>
                            <StackPanel Spacing="4">
                                <shad:CardTitle>Format</shad:CardTitle>
                                <shad:CardDescription>Choose the source and target formats.</shad:CardDescription>
                            </StackPanel>
                        </shad:Card.Header>
                        <StackPanel Spacing="16">
                            <ComboBox ItemsSource="{Binding InputFormats}"
                                      SelectedItem="{Binding SelectedInputFormat}"
                                      shad:ControlAssist.Label="Input format"/>
                            <ComboBox ItemsSource="{Binding OutputFormats}"
                                      SelectedItem="{Binding SelectedOutputFormat}"
                                      shad:ControlAssist.Label="Output format"/>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox x:Name="ConfigPathBox"
                                         Text="{Binding ConfigPath}"
                                         shad:ControlAssist.Label="Config file"/>
                                <Button Grid.Column="1"
                                        Classes="Outline"
                                        Content="Browse"
                                        Click="BrowseConfigPath_Click"
                                        IsEnabled="{Binding IsIdle}"
                                        VerticalAlignment="Bottom"/>
                            </Grid>
                        </StackPanel>
                        <shad:Card.Footer>
                            <Button Classes="Outline"
                                    Content="Load Config"
                                    Command="{Binding LoadConfigCommand}"
                                    HorizontalAlignment="Right"/>
                        </shad:Card.Footer>
                    </shad:Card>

                    <shad:Card HasShadow="True">
                        <shad:Card.Header>
                            <StackPanel Spacing="4">
                                <shad:CardTitle>Geometry</shad:CardTitle>
                                <shad:CardDescription>Normalize scale and input coordinate system.</shad:CardDescription>
                            </StackPanel>
                        </shad:Card.Header>
                        <StackPanel Spacing="16">
                            <NumericUpDown Value="{Binding ScaleFactor}"
                                           Minimum="0.0001"
                                           Maximum="100000"
                                           Increment="0.1"
                                           FormatString="F4"
                                           shad:ControlAssist.Label="Scale"/>
                            <ComboBox ItemsSource="{Binding AxisModes}"
                                      SelectedItem="{Binding SelectedAxisMode}"
                                      shad:ControlAssist.Label="Input axes"/>
                        </StackPanel>
                    </shad:Card>
                </UniformGrid>

                <shad:Card HasShadow="True">
                    <shad:Card.Header>
                        <StackPanel Spacing="4">
                            <shad:CardTitle>Files</shad:CardTitle>
                            <shad:CardDescription>Drop files and folders into fields or browse.</shad:CardDescription>
                        </StackPanel>
                    </shad:Card.Header>
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="16">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBox x:Name="InputPathBox"
                                     Text="{Binding InputPath}"
                                     shad:ControlAssist.Label="Input path"/>
                            <Button Grid.Column="1"
                                    Classes="Outline"
                                    Content="Browse"
                                    Click="BrowseInputPath_Click"
                                    IsEnabled="{Binding IsIdle}"
                                    VerticalAlignment="Bottom"/>
                        </Grid>
                        <Grid Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBox x:Name="AnimationPathBox"
                                     Text="{Binding AnimationPath}"
                                     IsEnabled="{Binding CanBrowseAnimation}"
                                     shad:ControlAssist.Label="Animation path"/>
                            <Button Grid.Column="1"
                                    Classes="Outline"
                                    Content="Browse"
                                    Click="BrowseAnimationPath_Click"
                                    IsEnabled="{Binding CanBrowseAnimation}"
                                    VerticalAlignment="Bottom"/>
                        </Grid>
                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBox x:Name="OutputPathBox"
                                     Text="{Binding OutputPath}"
                                     shad:ControlAssist.Label="Output path"/>
                            <Button Grid.Column="1"
                                    Classes="Outline"
                                    Content="Browse"
                                    Click="BrowseOutputPath_Click"
                                    IsEnabled="{Binding IsIdle}"
                                    VerticalAlignment="Bottom"/>
                        </Grid>
                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Text="{Binding BaseName}"
                                 shad:ControlAssist.Label="Name"/>
                    </Grid>
                </shad:Card>

                <UniformGrid Columns="2" ColumnSpacing="16">
                    <shad:Card HasShadow="True" IsEnabled="{Binding IsSourceOutput}">
                        <shad:Card.Header>
                            <StackPanel Spacing="4">
                                <shad:CardTitle>Source Engine</shad:CardTitle>
                                <shad:CardDescription>MDL compile output and material generation.</shad:CardDescription>
                            </StackPanel>
                        </shad:Card.Header>
                        <StackPanel Spacing="16">
                            <TextBox Text="{Binding ModelPath}"
                                     shad:ControlAssist.Label="Model path"/>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox x:Name="GameDirectoryBox"
                                         Text="{Binding GameDirectory}"
                                         shad:ControlAssist.Label="Game directory"/>
                                <Button Grid.Column="1"
                                        Classes="Outline"
                                        Content="Browse"
                                        Click="BrowseGameDirectory_Click"
                                        IsEnabled="{Binding IsIdle}"
                                        VerticalAlignment="Bottom"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox x:Name="EngineDirectoryBox"
                                         Text="{Binding EngineDirectory}"
                                         shad:ControlAssist.Label="Engine directory"/>
                                <Button Grid.Column="1"
                                        Classes="Outline"
                                        Content="Browse"
                                        Click="BrowseEngineDirectory_Click"
                                        IsEnabled="{Binding IsIdle}"
                                        VerticalAlignment="Bottom"/>
                            </Grid>
                            <CheckBox Content="Build VTF/VMT materials" IsChecked="{Binding BuildMaterials}"/>
                        </StackPanel>
                    </shad:Card>

                    <shad:Card HasShadow="True" IsEnabled="{Binding IsSourceOutput}">
                        <shad:Card.Header>
                            <StackPanel Spacing="4">
                                <shad:CardTitle>Physics</shad:CardTitle>
                                <shad:CardDescription>Generate a Source physics mesh during export.</shad:CardDescription>
                            </StackPanel>
                        </shad:Card.Header>
                        <StackPanel Spacing="16">
                            <ComboBox ItemsSource="{Binding PhysicsModes}"
                                      SelectedItem="{Binding SelectedPhysicsMode}"
                                      shad:ControlAssist.Label="Mode"/>
                            <NumericUpDown Value="{Binding PhysicsMass}"
                                           Minimum="0.1"
                                           Maximum="100000"
                                           Increment="10"
                                           FormatString="F1"
                                           IsEnabled="{Binding IsPhysicsEnabled}"
                                           shad:ControlAssist.Label="Mass"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <NumericUpDown Value="{Binding CoacdThreshold}"
                                               Minimum="0.0001"
                                               Maximum="1"
                                               Increment="0.001"
                                               FormatString="F4"
                                               IsEnabled="{Binding IsCoacdEnabled}"
                                               shad:ControlAssist.Label="CoACD threshold"/>
                                <NumericUpDown Grid.Column="1"
                                               Value="{Binding MaxConvexPieces}"
                                               Minimum="1"
                                               Maximum="128"
                                               Increment="1"
                                               FormatString="F0"
                                               IsEnabled="{Binding IsCoacdEnabled}"
                                               shad:ControlAssist.Label="Max pieces"/>
                            </Grid>
                            <NumericUpDown Value="{Binding MaxHullVertices}"
                                           Minimum="4"
                                           Maximum="256"
                                           Increment="1"
                                           FormatString="F0"
                                           IsEnabled="{Binding IsCoacdEnabled}"
                                           shad:ControlAssist.Label="Hull vertices"/>
                            <CheckBox Content="Generate mesh" IsChecked="{Binding GeneratePhysics}"/>
                        </StackPanel>
                    </shad:Card>
                </UniformGrid>

                <shad:Card HasShadow="True">
                    <shad:Card.Header>
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="4">
                                <shad:CardTitle>Material Search</shad:CardTitle>
                                <shad:CardDescription>Optional directory for texture and material lookup.</shad:CardDescription>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Button Classes="Outline"
                                        Content="Load Preview"
                                        Command="{Binding LoadPreviewCommand}"/>
                                <Button Classes="Primary"
                                        Content="Run Conversion"
                                        Command="{Binding RunConversionCommand}"/>
                            </StackPanel>
                        </Grid>
                    </shad:Card.Header>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox x:Name="MaterialDirectoryBox"
                                 Text="{Binding MaterialDirectory}"
                                 shad:ControlAssist.Label="Material directory"/>
                        <Button Grid.Column="1"
                                Classes="Outline"
                                Content="Browse"
                                Click="BrowseMaterialDirectory_Click"
                                IsEnabled="{Binding IsIdle}"
                                VerticalAlignment="Bottom"/>
                    </Grid>
                </shad:Card>
            </StackPanel>
            </controls:ScrollProgress.ScrollContent>
        </controls:ScrollProgress>
    </DockPanel>
</UserControl>
